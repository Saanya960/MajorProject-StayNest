<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StayNest:Edit your listing</title>
</head>
<body>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        Title:<input type="text" name="listing[title]" value="<%= listing.title %>" > <br>
        Description:<textarea name="listing[description]"><%= listing.description %></textarea> <br>
        Image:<input type="text" name="listing[image][url]" value="<%= listing.image.url %>" > <br>
        Price:<input type="number" name="listing[price]" value="<%= listing.price %>"> <br>
        Location:<input type="text" name="listing[location]" value="<%= listing.location %>"> <br>
        Country:<input type="text" name="listing[country]" value="<%= listing.country %>"> <br>
        <button>Edit</button>
    </form>
</body>
</html>
