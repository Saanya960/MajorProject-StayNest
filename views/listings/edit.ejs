<% layout('layouts/boilerplate.ejs') -%>

<div class="row">
    <div class="col-8 offset-2">
    <h3 style="color:#1ecbe1">Edit your Listing</h3>

    <form class="row g-3 needs-validation" novalidate method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <div class="mb-3">
                    <label class="form-label" for="title">Title:</label>
                    <input class="form-control" required type="text" id="title" name="listing[title]" value="<%= listing.title %>" placeholder="Edit title here..">
                    <div class="invalid-feedback">'Please enter a title!</div>
        </div>
            
        <div class="mb-3">
            <label class="form-label" for="desc">Description:</label>
            <textarea class="form-control" required id="desc" name="listing[description]" placeholder="Edit your place here..."><%= listing.description %>
            
            </textarea>
            <div class="invalid-feedback">'Please write description'</div>
        </div>

        <div class="mb-3">
            <label for="img" class="form-label">Image:</label>
            <input id="img" type="text" class="form-control" required name="listing[image][url]" value="<%= listing.image.url %>" placeholder="Enter image URL/link"> 
            <div class="invalid-feedback">'Please write image URL/link'</div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="mb-3">
                <label for="price" class="form-label">Price:</label>
                <input class="form-control" required id="price" type="number" name="listing[price]" value="<%= listing.price%>" placeholder="Edit your price."> 
                <div class="invalid-feedback">'Please enter price.'</div>
                </div>
            </div>
            <div class="col-8">
                <div class="mb-3">
                <label class="form-label"for="locate">Location:</label>
                <input class="form-control" required id="locate" type="text" name="listing[location]" value="<%= listing.location %>" placeholder="Edit Location.."> 
                <div class="invalid-feedback">'Please enter location'</div>
                </div>
            </div>
        </div>
        
        <div class="mb-3">
            <label class="form-label" for="country" >Country:</label>
            <input class="form-control" required id="country" type="text" name="listing[country]" value="<%= listing.country %>" placeholder="Edit Country..">
            <div class="invalid-feedback">'Please enter country'</div>
        </div>
        <button class="btn btn-primary">Edit this Listing</button>
    </form>
    </div>
</div>
