<% layout('layout/boilerplate') -%>
 <h3><%=listing.title %></h3>
    <ul>
     <li><%=listing.description%> </li>
        <li>&#8377; <%=listing.price%></li>
         <li><%=listing.location %></li>
         <li><%=listing.country%></li>
    </ul>
    <form method="get" action="/listings/<%=listing._id%>/edit"><button>Edit visiting list</button></form> 
        <form method="post" action="/listings/<%=listing._id%>?_method=delete"><button>Delete visiting list</button></form> 
</body>