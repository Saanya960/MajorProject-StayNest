<% layout('layouts/boilerplate.ejs') -%>
<div class="row">
    <div class="col-8 offset-2">

    <h3><%=listing.title%> :</h3>
    </div>
    <div class="col-6 offset-2">
    <div class="card">
        <img src="<%=listing.image.url %>" alt="<%= listing.title %>" class="card-img-top show-img-style">
        <div class="card-body">
            <p class="card-text">
               <b><%= listing.title %></b> <br>
                <i><%=listing.description %></i> <br>
                &#8377;<%= listing.price.toLocaleString('en-IN') %>
                <br>
                <%=listing.location %>
                <br>
                <%=listing.country %>
            </p>
        </div>
    </div>
    
    <a class="edit-link-style" href="/listings/<%= listing._id %>/edit">Edit this listing</a>
    <br> <br>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" >
        <button class="btn btn-primary">Delete this Listing</button>
    </form>
</div>
<div class="col-6 offset-2">
    <h4>Leave your Reviews</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="mb-3 mt-3 needs-validation" novalidate>
        <div class="mb-3 mt-3">
            <label class="form-label" for="rating">Ratings⭐</label>
            <input type="range" class="form-range" min="1" max="5" id="rating" name="review[rating]">
        </div>
        <div class="mb-3 mt-3">
            <label class="form-label"  class="form-control" for="comment">Comments</label>
            <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
            <div class="invalid-feedback">'Pls fill comment section.</div>
        </div>
        <button class="btn btn-primary">Post</button>
    </form>
    <br>
    <h4>See Reviews 👇</h4>
    <% for (let review of listing.reviews) { %>
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Sam Malhotra</h5>
                <h6 class="card-subtitle mb-2 text-body-secondary"><%= review.rating %>/5</h6>
                <p class="card-text"><%= review.comment %></p>
            </div>
        </div>
    <% } %>
</div>
</div>
