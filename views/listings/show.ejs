<% layout('layouts/boilerplate.ejs') -%>
<div class="row">
    <div class="col-8 offset-2">

    <h3>Listing Details :</h3>
    </div>
    <div class="col-6 offset-2">
    <div class="card">
        <img src="<%= imageUrl(listing.image.url) %>" alt="<%= listing.title %>" class="card-img-top show-img-style">
        <div class="card-body">
            <p class="card-text">
               <b><%= listing.title %></b> <br>
                <i><%=listing.description %></i> <br>
                &#8377;<%= listing.price.toLocaleString('en-IN') %>
                <br>
                <%=listing.location %>
                <br>
                <%=listing.country %>
            </p>
        </div>
    </div>
    
    <a class="edit-link-style" href="/listings/<%= listing._id %>/edit">Edit this listing</a>
    <br> <br>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" >
        <button class="btn btn-primary">Delete this Listing</button>
    </form>
</div>
</div>
